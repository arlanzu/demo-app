@model DemoApp.Models.ViewModels.AdminSubmissionsViewModel

@{
    ViewData["Title"] = "Admin";
}

<section class="contact-page">
    <div class="contact-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="contact-title mb-0">Submitted Requests</h1>
            <a asp-action="Create" class="btn btn-primary">Create Request</a>
        </div>

        @if (!Model.Submissions.Any())
        {
            <p class="mb-0">No requests have been submitted yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Id</th>
                            <th scope="col">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Phone</th>
                            <th scope="col">Message</th>
                            <th scope="col">Submitted (UTC)</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var submission in Model.Submissions)
                        {
                            <tr>
                                <td>@submission.Id</td>
                                <td>@submission.Name</td>
                                <td>@submission.Email</td>
                                <td>@(string.IsNullOrWhiteSpace(submission.Phone) ? "-" : submission.Phone)</td>
                                <td>@submission.Message</td>
                                <td>@submission.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@submission.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                        <a asp-action="Edit" asp-route-id="@submission.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <form asp-action="Delete" asp-route-id="@submission.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this request?');">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
