@model DemoApp.Models.ViewModels.AdminReplyViewModel

@{
    ViewData["Title"] = "Reply";
}

<section class="contact-page">
    <div class="contact-card admin-card">
        <h1 class="contact-title">Reply To Request</h1>

        <div class="mb-3">
            <strong>Name:</strong> @Model.Name
        </div>
        <div class="mb-3">
            <strong>Email:</strong> @Model.Email
        </div>
        <div class="mb-3">
            <strong>Message:</strong>
            <p class="mb-0">@Model.Message</p>
        </div>

        <form asp-action="Reply" asp-route-id="@Model.Id" method="post" class="contact-form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="Name" type="hidden" />
            <input asp-for="Email" type="hidden" />
            <input asp-for="Message" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Reply" class="form-label"></label>
                <textarea asp-for="Reply" class="form-control" rows="6" placeholder="Write your reply..."></textarea>
                <span asp-validation-for="Reply" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Save Reply</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
