@model DemoApp.Models.ViewModels.ContactFormViewModel

@{
    ViewData["Title"] = "Contact";
}

<section class="contact-page">
    <div class="contact-card">
        <h1 class="contact-title">Contact Us</h1>

        @if (TempData["ContactInfoMessage"] is string infoMessage)
        {
            <div class="alert alert-info" role="alert">@infoMessage</div>
        }

        <form asp-action="Contact" asp-controller="Contact" method="post" class="contact-form">
            @Html.AntiForgeryToken()
            <input asp-for="SubmissionToken" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert" aria-live="polite"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" autocomplete="name" placeholder="Your full name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" autocomplete="tel" placeholder="Optional" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Message" class="form-label"></label>
                <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your message here"></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <button type="submit" class="btn contact-submit-btn w-100">Submit</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
